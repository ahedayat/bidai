# =============================================================================
# Bidai — Persian Tender Document QA MVP
# Copy this file to `.env` and fill in your values. Never commit `.env`.
# =============================================================================

# --- Required for indexing and querying (OpenAI) ---
# Your OpenAI API key. Required for real PDF indexing and RAG answers.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- OpenAI models ---
# Embedding model used when indexing chunks into Chroma.
EMBEDDING_MODEL=text-embedding-3-small

# Chat model used for Persian RAG answer generation.
CHAT_MODEL=gpt-4o-mini

# --- Local vector store ---
# Directory where Chroma persists indexed collections (gitignored).
CHROMA_PERSIST_DIR=data/chroma

# --- Chunking parameters ---
# Target chunk size in characters (Persian-aware splitting).
CHUNK_SIZE=1000

# Overlap between consecutive chunks (characters).
CHUNK_OVERLAP=150

# --- Retrieval ---
# Number of chunks retrieved per question (top-k).
TOP_K=4

# --- Logging (optional) ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional log file path (relative to project root or absolute).
# Leave empty for console-only logging.
# LOG_FILE=logs/bidai.log
